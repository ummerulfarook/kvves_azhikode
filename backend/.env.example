# Environment configuration for KVVA Management System
# Copy this file to .env and fill in the values

# ─────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production-min-50-chars
DEBUG=False

# ─────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────
DB_NAME=kvva_db
DB_USER=kvva_user
DB_PASSWORD=kvva_strong_password_here
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────
# ALLOWED HOSTS (comma-separated)
# ─────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# ─────────────────────────────────────────────────────
# CORS (frontend origin)
# ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100

# ─────────────────────────────────────────────────────
# MEDIA AND STATIC FILES
# ─────────────────────────────────────────────────────
MEDIA_ROOT=C:/kvva/media
STATIC_ROOT=C:/kvva/staticfiles

# ─────────────────────────────────────────────────────
# JWT TOKEN LIFETIMES
# ─────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
